{
  "expo": {
    "name": "포틴AI",
    "slug": "forteenai",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.forteenai.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "학습 문제 사진 촬영 및 첨부를 위해 권한이 필요합니다.",
        "NSCameraUsageDescription": "학습 문제 사진 촬영 및 첨부를 위해 권한이 필요합니다.",
        "NSMicrophoneUsageDescription": "학습 문제 사진 촬영 및 첨부를 위해 권한이 필요합니다."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/icon.png"
      },
      "package": "com.forteenai.app"
    },
    "extra": {
      "webAppUrl": "https://forteenai.com",
      "eas": {
        "projectId": "c68010ef-6472-4dcd-bd45-36b3cc3d654e"
      }
    },
    "owner": "forteenai",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "scheme": "forteenai",
    "plugins": [
      "expo-notifications"
    ]
  }
}
