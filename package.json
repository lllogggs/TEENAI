{
  "name": "forteenai",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/validate-env.mjs --target=client && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "node scripts/lint.mjs",
    "test": "node --test --experimental-strip-types tests/**/*.test.ts",
    "db:projects": "node scripts/run-supabase-cli.mjs projects list",
    "db:link": "node scripts/run-supabase-cli.mjs link --project-ref hpoekvinyjbymnctggih",
    "db:migrations": "node scripts/run-supabase-cli.mjs migration list",
    "db:push": "node scripts/run-supabase-cli.mjs db push"
  },
  "dependencies": {
    "@google-cloud/text-to-speech": "^6.4.0",
    "@google/genai": "^1.34.0",
    "@supabase/supabase-js": "^2.91.1",
    "@tailwindcss/typography": "^0.5.19",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "recharts": "^3.6.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "supabase": "^2.92.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
